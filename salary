              <div className="absolute top-0 left-1/2 w-px h-6 bg-emerald-300 -ml-px"></div>
              <div className="absolute top-6 left-[16.66%] right-[16.66%] h-px bg-emerald-300"></div>
              <div className="absolute top-6 left-[16.66%] w-px h-6 bg-emerald-300"></div>
              <div className="absolute top-6 left-1/2 w-px h-6 bg-emerald-300 -ml-px"></div>
              <div className="absolute top-6 right-[16.66%] w-px h-6 bg-emerald-300"></div>
            </div>
            <div className="block lg:hidden h-8 w-px bg-emerald-300 mx-auto"></div>

            {/* Level 2: Sub Divisions */}
            <div className="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-6 relative z-10 max-w-5xl mx-auto">
              
              {/* Office */}
              <div className="space-y-6">
                <div className="bg-slate-800 text-white font-bold py-3 px-4 rounded-xl text-center text-sm flex items-center justify-center gap-2 shadow-md">
                  <Users size={18} className="text-emerald-300" /> 사무실 (Office)
                </div>
                <EmployeeCard 
                  name="Samantha Tucker"
                  roleKo="사무 관리"
                  roleEn="Office Admin"
                  icon={Users}
                  isPlant={true}
                  payData={[
                    { label: "고정 연봉 (Yearly Salary)", value: "$57,500" }
                  ]}
                />
              </div>

              {/* Trucking */}
              <div className="space-y-6">
                <div className="bg-slate-800 text-white font-bold py-3 px-4 rounded-xl text-center text-sm flex items-center justify-center gap-2 shadow-md">
                  <Truck size={18} className="text-emerald-300" /> 운송 부서 (Trucking of Bait)
                </div>
                <EmployeeCard 
                  name="James M Defelice II"
                  roleKo="운송 담당 (1099)"
                  roleEn="Trucking (Contractor)"
                  icon={Truck}
                  isPlant={true}
                  payData={[
                    { label: "기본 시급 (Hourly)", value: "$75.00 / hr" },
                    { label: "고용 형태", value: "1099 독립 계약자" }
                  ]}
                />
              </div>

              {/* Plant Floor Overview */}
              <div className="space-y-6">
                <div className="bg-slate-800 text-white font-bold py-3 px-4 rounded-xl text-center text-sm flex items-center justify-center gap-2 shadow-md">
                  <Factory size={18} className="text-emerald-300" /> 생산 현장 (Plant Floor)
                </div>
                
                <div className="bg-white p-6 rounded-2xl shadow-lg border-t-4 border-emerald-500 flex flex-col h-full justify-center text-center">
                  <Users size={32} className="mx-auto text-emerald-500 mb-3" />
                  <h3 className="text-xl font-bold text-slate-800 mb-2">일반 공장 직원</h3>
                  <p className="text-slate-500 text-sm mb-4">Fish Boxing 및 일반 생산 업무</p>
                  <div className="bg-emerald-50 text-emerald-800 font-extrabold py-2 px-4 rounded-lg inline-block mx-auto text-lg">
                    총 {plantEmployees.length} 명
                  </div>
                </div>
              </div>
            </div>

            {/* Plant Employees Roster Section */}
            <div className="mt-16">
              <div className="bg-white rounded-3xl shadow-lg border border-slate-200 overflow-hidden">
                <div className="bg-gradient-to-r from-emerald-800 to-emerald-700 py-5 px-8 flex items-center justify-between">
                  <div className="flex items-center gap-3">
                    <div className="p-2 bg-white/20 rounded-lg backdrop-blur-sm">
                      <Users size={24} className="text-white" />
                    </div>
                    <h3 className="font-extrabold text-white text-xl">공장 직원 명부 및 시급 상세 (Plant Roster)</h3>
                  </div>
                </div>
                
                <div className="p-8 bg-slate-50/50">
                  <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                    {plantEmployees.map((emp, idx) => (
                      <div key={idx} className="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 hover:border-emerald-400 hover:shadow-md transition-all duration-200">
                        <h4 className="font-bold text-slate-800 mb-3 pb-2 border-b border-slate-100">{emp.name}</h4>
                        <div className="space-y-2 text-sm">
                          <div className="flex justify-between items-center">
                            <span className="text-slate-500">기본 시급 (Hourly)</span>
                            <span className="font-bold text-slate-800">${emp.hourly.toFixed(2)}</span>
                          </div>
                          <div className="flex justify-between items-center">
                            <span className="text-slate-500">초과 근무 (OT x1.5)</span>
                            <span className="font-bold text-emerald-600">${emp.ot.toFixed(2)}</span>
                          </div>
                          {emp.boxing > 0 && (
                            <div className="flex justify-between items-center pt-1 border-t border-dashed border-slate-100">
                              <span className="text-slate-500">Fish Boxing 수당</span>
                              <span className="font-bold text-indigo-600">+${emp.boxing.toFixed(2)}</span>
                            </div>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            {/* Plant Hourly Cost Simulator */}
            <div className="mt-20 bg-white p-8 rounded-3xl shadow-lg border border-slate-100">
              <div className="flex flex-col lg:flex-row lg:items-end justify-between mb-8 gap-4">
                <div>
                  <h3 className="text-2xl font-extrabold text-slate-800 flex items-center gap-3 mb-3">
                    <div className="p-2 bg-emerald-100 text-emerald-600 rounded-lg">
                      <Clock size={24} /> 
                    </div>
                    주간 인건비 시뮬레이터 (공장 운영 시간 기준)
                  </h3>
                  <p className="text-slate-500 text-sm font-medium leading-relaxed">
                    공장 가동 시간에 따른 <strong className="text-slate-700">공장 직원 {plantEmployees.length}명</strong>의 예상 주간 인건비입니다.<br/>
                    <span className="text-slate-400">※ 운송(Trucking) 및 사무직(Shawn, Samantha) 고정 급여는 제외된 순수 생산 라인 근로자 인건비입니다. / Fish Boxing 수당은 별도 합산.</span>
                  </p>
                </div>

                <div className="flex gap-4 p-4 bg-slate-50 rounded-xl border border-slate-200 shadow-inner">
                  <div>
                    <label className="block text-xs font-bold text-slate-500 mb-1">정규 시간 (Hours/Wk)</label>
                    <input 
                      type="number" 
                      value={plantSimHours} 
                      onChange={(e) => setPlantSimHours(Number(e.target.value) || 0)}
                      className="w-24 px-3 py-2 rounded-lg border border-slate-300 font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500"
                    />
                  </div>
                  <div>
                    <label className="block text-xs font-bold text-slate-500 mb-1">OT 시간 (Overtime)</label>
                    <input 
                      type="number" 
                      value={plantSimOT} 
                      onChange={(e) => setPlantSimOT(Number(e.target.value) || 0)}
                      className="w-24 px-3 py-2 rounded-lg border border-slate-300 font-bold text-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-500"
                    />
                  </div>
                </div>
              </div>

              <div className="overflow-x-auto rounded-xl border border-slate-200">
                <table className="w-full text-sm text-left">
                  <thead className="text-xs text-slate-600 uppercase bg-slate-100 border-b border-slate-200">
                    <tr>
                      <th className="px-6 py-4 font-extrabold">직원명 (Employee)</th>
                      <th className="px-4 py-4 font-bold text-right border-r border-slate-200">단가 (Hourly / OT)</th>
                      <th className="px-6 py-4 font-bold text-right">정규 급여 ({plantSimHours}h)</th>
                      <th className="px-6 py-4 font-bold text-right text-emerald-600">OT 급여 ({plantSimOT}h)</th>
                      <th className="px-6 py-4 font-extrabold text-right bg-emerald-50 text-slate-800">예상 주급 합계</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-slate-100">
                    {plantEmployees.map((emp, idx) => {
                      const regularPay = emp.hourly * plantSimHours;
                      const otPay = emp.ot * plantSimOT;
                      const weeklyTotal = regularPay + otPay;
                      
                      return (
                        <tr key={idx} className="hover:bg-slate-50">
                          <td className="px-6 py-3 font-medium text-slate-700">{emp.name}</td>
                          <td className="px-4 py-3 text-right text-slate-400 border-r border-slate-200">
                            ${emp.hourly.toFixed(2)} / <span className="text-emerald-500">${emp.ot.toFixed(2)}</span>
                          </td>
                          <td className="px-6 py-3 text-right font-medium">${regularPay.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                          <td className="px-6 py-3 text-right font-medium text-emerald-600">${otPay.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                          <td className="px-6 py-3 text-right font-bold bg-emerald-50/50 text-slate-800">${weeklyTotal.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                        </tr>
                      )
                    })}
                    
                    {/* Plant Grand Total */}
                    {(() => {
                      const totalRegular = plantEmployees.reduce((sum, emp) => sum + (emp.hourly * plantSimHours), 0);
                      const totalOT = plantEmployees.reduce((sum, emp) => sum + (emp.ot * plantSimOT), 0);
                      const lineTotal = totalRegular + totalOT;
                      
                      const shawnYearly = 110000; // 90k Base + 20k Bonus
                      const samanthaYearly = 57500;
                      const totalFixedWeekly = (shawnYearly + samanthaYearly) / 52; // 연봉을 주간 비용으로 환산
                      
                      const grandTotal = lineTotal + totalFixedWeekly;
                      const monthlyEst = grandTotal * 4.33; // 평균 월간 주수 곱하기

                      return (
                        <>
                          <tr className="bg-slate-50/80">
                            <td colSpan="4" className="px-6 py-4 text-right font-bold text-slate-600">생산 라인 근로자 주급 합계 (Line Workers)</td>
                            <td className="px-6 py-4 text-right font-bold text-slate-800">${lineTotal.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                          </tr>
                          <tr className="bg-slate-50/80 border-b-2 border-emerald-200">
                            <td colSpan="4" className="px-6 py-4 text-right font-bold text-slate-600">고정 인건비 주간 환산 (Fixed: Manager & Office)</td>
                            <td className="px-6 py-4 text-right font-bold text-slate-800">${totalFixedWeekly.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                          </tr>
                          <tr className="bg-slate-800 text-white">
                            <td colSpan="2" className="px-6 py-5 font-black text-lg text-emerald-300 text-right">
                              공장 총 주간 인건비 (Grand Total)
                            </td>
                            <td className="px-6 py-5 text-right font-bold">${totalRegular.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                            <td className="px-6 py-5 text-right font-bold text-emerald-400">${totalOT.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                            <td className="px-6 py-5 text-right">
                              <div className="font-black text-xl text-yellow-400 drop-shadow-md">
                                ${grandTotal.toLocaleString(undefined, {minimumFractionDigits: 2})}
                              </div>
                              <div className="text-xs font-medium text-slate-400 mt-1 uppercase tracking-wide">
                                월간(Monthly) 예상: <span className="text-slate-300">${monthlyEst.toLocaleString(undefined, {minimumFractionDigits: 2})}</span>
                              </div>
                            </td>
                          </tr>
                        </>
                      );
                    })()}
                  </tbody>
                </table>
              </div>
            </div>

          </div>
        </div>
      )}

    </div>
  );
};

export default Dashboard;
