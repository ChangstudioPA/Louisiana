const EmployeeCard = ({ name, roleKo, roleEn, icon: Icon, payData, isMain, isPlant }) => {
  const theme = {
    mainBorder: isPlant ? 'border-emerald-500' : 'border-amber-400',
    mainShadow: isPlant ? 'shadow-emerald-100/50' : 'shadow-amber-100/50',
    mainBadgeBg: isPlant ? 'bg-emerald-100' : 'bg-amber-100',
    mainBadgeText: isPlant ? 'text-emerald-800' : 'text-amber-800',
    mainIconBg: isPlant ? 'from-emerald-500 to-emerald-600' : 'from-amber-400 to-amber-500',
    
    subBorder: isPlant ? 'border-teal-500' : 'border-blue-500',
    subShadow: isPlant ? 'shadow-teal-100/50' : 'shadow-blue-100/50',
    subBadgeBg: isPlant ? 'bg-teal-50' : 'bg-blue-50',
    subBadgeText: isPlant ? 'text-teal-700' : 'text-blue-700',
    subIconBg: isPlant ? 'from-teal-500 to-teal-600' : 'from-blue-500 to-blue-600',
  };

  const currentTheme = isMain ? 
    { border: theme.mainBorder, shadow: theme.mainShadow, badgeBg: theme.mainBadgeBg, badgeText: theme.mainBadgeText, iconBg: theme.mainIconBg } : 
    { border: theme.subBorder, shadow: theme.subShadow, badgeBg: theme.subBadgeBg, badgeText: theme.subBadgeText, iconBg: theme.subIconBg };

  return (
    <div className={`relative flex flex-col p-6 rounded-2xl shadow-lg bg-white z-10
      border-t-4 ${currentTheme.border} ${currentTheme.shadow}
      transition-transform duration-300 hover:-translate-y-1 hover:shadow-xl`}
    >
      <div className="flex items-start justify-between mb-4">
        <div>
          <div className={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-bold mb-3
            ${currentTheme.badgeBg} ${currentTheme.badgeText}`}>
            {isMain && <Award size={14} />}
            {roleKo} <span className="font-medium opacity-75">| {roleEn}</span>
          </div>
          <h2 className="text-xl font-extrabold text-slate-800 tracking-tight leading-tight">{name}</h2>
        </div>
        <div className={`p-3.5 rounded-2xl shadow-inner text-white bg-gradient-to-br ${currentTheme.iconBg} flex-shrink-0 ml-2`}>
          <Icon size={24} />
        </div>
      </div>
      
      <div className="mt-2 space-y-2.5 flex-grow">
